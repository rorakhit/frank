# Copy this file to .env and fill in your real values.
# NEVER commit .env — only .env.example belongs in git.

# =============================================================================
# Required — Plaid
# =============================================================================
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox                      # sandbox | development | production
PLAID_WEBHOOK_URL=https://your-app-url.railway.app/webhook

# =============================================================================
# Required — Supabase
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # service role, NOT the anon key

# =============================================================================
# Required — App security
# =============================================================================
SETUP_SECRET=your_random_secret        # generate with: openssl rand -hex 32

# =============================================================================
# Optional — AI categorization (uses Claude)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Optional — Gmail alerts
# Without these, email alerts and paycheck reports are silently skipped.
# =============================================================================
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password   # generate at myaccount.google.com/apppasswords
GMAIL_RECIPIENT=you@gmail.com                # optional — defaults to GMAIL_USER if not set

# =============================================================================
# Optional — Notion dashboard
# Without NOTION_TOKEN, all Notion writes are skipped.
# The built-in web dashboard (/dashboard) works without Notion.
# =============================================================================
NOTION_TOKEN=secret_...
NOTION_ROOT_PAGE_ID=your_autobudget_root_page_id

# =============================================================================
# Optional
# =============================================================================
PORT=3000
